# ================================================
# PTrust Oracle — Environment Variables
# Copy this file to .env.local and fill in values
# ================================================

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/ptrust_oracle?retryWrites=true&w=majority

# Pi Network Server API Key (from developer.minepi.com)
PI_API_KEY=your_pi_server_api_key_here

# Sandbox mode: true = testing, false = production
PI_SANDBOX=true
